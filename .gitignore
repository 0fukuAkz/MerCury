# Python build / install artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
# (no trailing slash so the patterns also match `.venv` when it's a symlink
# pointing at `venv/` — see CLAUDE.md note on the canonical venv name.)
venv
ENV
env
.venv

# IDE / editors
.idea/
*.swp
*.swo
*~

# VSCode/Cursor: ignore most of .vscode/ but track the shared
# project-level config (settings.json + extensions.json) so every
# contributor gets the same venv auto-activation and recommended
# extensions on first clone. Per-user files (launch.json,
# user-specific tasks, *.code-workspace state) stay ignored.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db

# Test / coverage / lint caches
.coverage
coverage.xml
coverage_report.txt
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
# Ad-hoc pytest stdout dumps at repo root (e.g. `pytest > test_out.txt`)
/test_out.txt
/test_output.txt

# Environment files (.env.example IS tracked; .env / .env.local are not)
.env
.env.local

# Runtime / process state
*.pid
data/.mercury.pid
data/.encryption.key
# Per-install encryption salt (security/encryption.py derives keys from it).
# Untracked so each deployment generates its own — a shared committed salt
# weakens per-install key derivation. Local file is kept.
data/.encryption.salt

# SQLite databases + WAL files
*.db
*.db-shm
*.db-wal
*.db.bak

# Logs (the directory is kept via data/.gitkeep; contents are not)
logs/*.log
logs/*.txt
logs/*.json
# LockManager creates .lock files in the log dir during normal operation
logs/*.lock

# Operator-supplied runtime data (recipient lists, generated attachments,
# rendered preview HTML). These belong to the deployment, not the repo.
data/*.csv
data/*.txt
data/attachments/*.html
data/recipients/*
!data/.gitkeep

# Operator-side `templates/` is a *runtime* directory the operator
# populates with their own email templates (see Deployment.md). Distinct
# from `src/mercury/web/templates/`, which IS the bundled web-app
# templates package_data and MUST stay tracked.
templates/attachment.html
templates/redirect.html

# Adhoc debugging / exploration scripts (not part of the project)
fix_*.py
patch_*.py
setup_worker.py
docs/desktop-bundling-plan.md
.claude/settings.local.json
