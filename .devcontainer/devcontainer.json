{
  "name": "MerCury",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": false
    }
  },

  // Runs once on container creation. Installs WeasyPrint/cryptography
  // system deps, builds the project venv, installs runtime + dev deps,
  // wires pre-commit hooks if configured, and seeds .env from the
  // template on first boot.
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  // Web dashboard. Auto-previewed in VSCode/Codespaces' Simple Browser
  // when the user runs `python run.py` or `make dev`.
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "MerCury dashboard",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.debugpy",
        "tamasfe.even-better-toml",
        "DavidAnson.vscode-markdownlint",
        "github.vscode-github-actions"
      ],
      "settings": {
        // Container-local venv — distinct from the host's .venv symlink
        // which won't exist inside the container.
        "python.defaultInterpreterPath": "/workspaces/MerCury/venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "[python]": {
          "editor.formatOnSave": false,
          "editor.codeActionsOnSave": {
            "source.organizeImports.ruff": "explicit"
          }
        },
        "files.exclude": {
          "**/__pycache__": true,
          "**/.pytest_cache": true,
          "**/.mypy_cache": true,
          "**/.ruff_cache": true,
          "**/*.egg-info": true
        }
      }
    }
  },

  "remoteUser": "vscode",

  // The default workspace mount path Codespaces uses. Listed
  // explicitly so the python.defaultInterpreterPath above stays
  // accurate across host machines.
  "workspaceFolder": "/workspaces/MerCury"
}
