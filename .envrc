# direnv config: auto-activate the project's venv when you `cd` into
# this directory, and de-activate on exit. Works in bash, zsh, fish,
# tcsh, elvish, and (via a community port) PowerShell — see
# https://direnv.net for the per-shell hook setup. One-time per-repo
# step after install: run `direnv allow` once.
#
# If you don't use direnv, you have two other options:
#   - Run `source ./activate.sh`  (bash/zsh/fish, macOS/Linux)
#   - Run `. .\activate.ps1`      (PowerShell on Windows)
# Either drops you in the venv for the current terminal session.

# .venv/ is the repo-wide canonical name (matches install.sh/install.ps1,
# .vscode/settings.json, .devcontainer/*). Still checks the legacy `venv/`
# name too so an existing checkout from before this convention was
# standardized keeps auto-activating instead of silently doing nothing.
export VIRTUAL_ENV_DISABLE_PROMPT=1
if [ -d ".venv" ]; then
    export VIRTUAL_ENV="$PWD/.venv"
    export PATH="$VIRTUAL_ENV/bin:$PATH"
    unset PYTHONHOME
elif [ -d "venv" ]; then
    export VIRTUAL_ENV="$PWD/venv"
    export PATH="$VIRTUAL_ENV/bin:$PATH"
    unset PYTHONHOME
else
    echo "direnv: no .venv/ or venv/ found — run \`make install-dev\` or \`python3.12 -m venv .venv && pip install -e .\`"
fi

# Surface a helpful prompt prefix even outside the activate script's
# scope (e.g., for shells that strip $VIRTUAL_ENV in subshells).
export PYTHONDONTWRITEBYTECODE=1
