# =============================================================================
# MerCury configuration — copy to .env and fill in:  cp .env.example .env
#
# The installer (./install.sh / .\install.ps1) generates a ready-to-run .env
# for you; this file documents every variable for manual and production setup.
#
# NOTE: `python run.py` loads .env automatically. The `mercury` CLI does NOT —
# export the vars first:  set -a; . .env; set +a
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
# Session signing / token secret.
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me

# First-admin bootstrap. The app creates this user on first boot ONLY when all
# three are set (there is no admin/admin fallback). Change the password after.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@example.com

# development | production. Production hard-fails on a dev SECRET_KEY, a SQLite
# DATABASE_URL, or in-memory rate-limit storage (see the escape hatches below).
FLASK_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Unset = SQLite in your OS user-data dir. Production wants Postgres:
# DATABASE_URL=postgresql://mercury:mercury@localhost:5432/mercury
# ALLOW_SQLITE_IN_PRODUCTION=1   # consciously accept SQLite in production

# ── Tracking & links (public-facing) ─────────────────────────────────────────
# Public base URL for open pixels, click wrapping, and unsubscribe links.
TRACKING_BASE_URL=https://mail.example.com
# HMAC secret for signed unsubscribe links (falls back to SECRET_KEY if unset).
# UNSUBSCRIBE_SECRET=

# ── Encryption (stored SMTP credentials) ─────────────────────────────────────
# Keys derive from a passphrase + a per-install salt that MerCury generates
# automatically at <data-dir>/.encryption.salt — do not commit that file.
# ENCRYPTION_PASSWORD=
# ENCRYPTION_KEY=          # or supply a raw key directly
# ENCRYPTION_SALT=         # override the auto-generated salt (advanced)

# ── Horizontal scale-out (opt-in; leave unset for the single-worker default) ──
# SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/0   # cross-worker SocketIO fan-out
# RATE_LIMIT_STORAGE=redis://localhost:6379/1        # durable rate limits
# CAMPAIGN_EXECUTION_MODE=worker                     # offload sending to the arq worker
# CAMPAIGN_QUEUE_REDIS=redis://localhost:6379/2
# WEB_CONCURRENCY=4         # gunicorn workers (requires the three above)

# ── Observability (opt-in; needs the `observability` extra) ──────────────────
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# MERCURY_RELEASE=2.1.1
# METRICS_TOKEN=           # gate GET /metrics (open if unset)

# ── Web security ─────────────────────────────────────────────────────────────
# CORS_ORIGINS=https://app.example.com
# API_KEYS=key1,key2       # optional API-key auth for programmatic access
# SESSION_COOKIE_SECURE=1  # (forced on in production)
# SESSION_COOKIE_SAMESITE=Lax
# HSTS_MAX_AGE=31536000
# ALLOW_INTERNAL_WEBHOOKS=0

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_JSON_OUTPUT=1        # JSON logs (forced on in production)
# SQL_DEBUG=0
