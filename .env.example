# MerCury Production Environment Configuration
# Copy this file to .env and fill in the values

# Core Flask Settings
FLASK_ENV=production
FLASK_DEBUG=0

# Security (CRITICAL: Change these in production!)
# Generate a secure key: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secure-secret-key-here
ADMIN_PASSWORD=your-initial-admin-password

# Database Configuration
# PostgreSQL format: postgresql://user:password@localhost:5432/dbname
# SQLite format: sqlite:///instance/mercury.db
DATABASE_URL=postgresql://mercury:mercury@db:5432/mercury

# Logging
LOG_LEVEL=INFO
LOG_JSON_OUTPUT=True

# Email Settings (Optional defaults)
# DEFAULT_SENDER_NAME="MerCury Platform"
# DEFAULT_FROM_EMAIL=noreply@example.com
