# MerCury Production Environment Configuration
# Copy this file to .env and fill in the values

# Core Flask Settings
FLASK_ENV=production
FLASK_DEBUG=0

# Security (CRITICAL: Change these in production!)
# Generate a secure key: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secure-secret-key-here

# First-admin bootstrap. All three are required together — the app refuses
# to auto-create an admin user without them and you'll be locked out of
# the web UI on first boot. (There is no admin/admin fallback.)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-initial-admin-password
ADMIN_EMAIL=admin@yourdomain.com

# Tracking link base URL — required for any campaign that enables tracking.
# Must be the publicly-reachable URL of the web app (typically https://...).
TRACKING_BASE_URL=https://mail.yourdomain.com

# Optional: programmatic API keys for /api/* (comma-separated).
# API_KEYS=key1,key2,key3

# Optional: rate-limit storage (defaults to memory:// for dev, redis://... in prod).
# RATE_LIMIT_STORAGE=redis://redis:6379/0

# Database Configuration
# PostgreSQL format: postgresql://user:password@localhost:5432/dbname
# SQLite format: sqlite:///instance/mercury.db
DATABASE_URL=postgresql://mercury:mercury@db:5432/mercury

# Logging
LOG_LEVEL=INFO
LOG_JSON_OUTPUT=True

# Email Settings (Optional defaults)
# DEFAULT_SENDER_NAME="MerCury Platform"
# DEFAULT_FROM_EMAIL=noreply@example.com
